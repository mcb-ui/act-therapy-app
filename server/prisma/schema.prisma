generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress  Progress[]
  values    Value[]
  actions   Action[]
  favorites Favorite[]
  exerciseData ExerciseData[]
}

model Progress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  exerciseId  String
  completed   Boolean  @default(false)
  score       Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Value {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String
  description String
  importance  Int
  alignment   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Action {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  valueId     String?
  title       String
  description String?
  completed   Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  exerciseId  String
  exerciseName String
  createdAt   DateTime @default(now())

  @@unique([userId, exerciseId])
}

model ExerciseData {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  exerciseId  String
  exerciseName String
  data        String   // JSON string containing exercise responses
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
